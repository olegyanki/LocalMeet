{
  "version": 8,
  "name": "Locals Light (Expo)",
  "metadata": {
    "mapbox:autocomposite": true
  },
  "sources": {
    "mapbox-streets": {
      "type": "vector",
      "url": "mapbox://mapbox.mapbox-streets-v8"
    }
  },
  "glyphs": "mapbox://fonts/mapbox/{fontstack}/{range}.pbf",
  "sprite": "mapbox://sprites/mapbox/streets-v12",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "#F7FAFC"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "mapbox-streets",
      "source-layer": "water",
      "paint": {
        "fill-color": "#DDEAF6"
      }
    },
    {
      "id": "waterway",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "waterway",
      "paint": {
        "line-color": "#D0E2F2",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          8,
          0.5,
          14,
          2
        ]
      }
    },
    {
      "id": "landuse",
      "type": "fill",
      "source": "mapbox-streets",
      "source-layer": "landuse",
      "paint": {
        "fill-color": "#F2F6F8",
        "fill-opacity": 0.7
      }
    },
    {
      "id": "parks",
      "type": "fill",
      "source": "mapbox-streets",
      "source-layer": "landuse",
      "filter": ["==", ["get", "class"], "park"],
      "paint": {
        "fill-color": "#EAF4EA",
        "fill-opacity": 0.75
      }
    },
    {
      "id": "road-casing",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "road",
      "paint": {
        "line-color": "#E8EEF3",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          10,
          1,
          14,
          5,
          18,
          20
        ],
        "line-opacity": 0.9
      }
    },
    {
      "id": "road-main",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "road",
      "paint": {
        "line-color": "#FFFFFF",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          10,
          0.6,
          14,
          3.2,
          18,
          14
        ],
        "line-opacity": 0.95
      }
    },
    {
      "id": "road-minor",
      "type": "line",
      "source": "mapbox-streets",
      "source-layer": "road",
      "filter": ["in", ["get", "class"], ["literal", ["street", "street_limited", "service", "path"]]],
      "paint": {
        "line-color": "#FFFFFF",
        "line-width": [
          "interpolate",
          ["linear"],
          ["zoom"],
          12,
          0.4,
          16,
          2.0,
          18,
          6
        ],
        "line-opacity": 0.7
      }
    },
    {
      "id": "buildings",
      "type": "fill",
      "source": "mapbox-streets",
      "source-layer": "building",
      "minzoom": 14,
      "paint": {
        "fill-color": "#EEF2F6",
        "fill-opacity": 0.55
      }
    },
    {
      "id": "place-labels",
      "type": "symbol",
      "source": "mapbox-streets",
      "source-layer": "place_label",
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["DIN Pro Medium", "Arial Unicode MS Bold"],
        "text-size": [
          "interpolate",
          ["linear"],
          ["zoom"],
          4,
          10,
          8,
          14,
          12,
          18
        ],
        "text-max-width": 8,
        "text-allow-overlap": false
      },
      "paint": {
        "text-color": "#9AA7B2",
        "text-halo-color": "#F7FAFC",
        "text-halo-width": 1.2
      }
    },
    {
      "id": "poi-labels",
      "type": "symbol",
      "source": "mapbox-streets",
      "source-layer": "poi_label",
      "minzoom": 14,
      "layout": {
        "text-field": ["coalesce", ["get", "name_en"], ["get", "name"]],
        "text-font": ["DIN Pro Regular", "Arial Unicode MS Regular"],
        "text-size": 12,
        "text-offset": [0, 0.6],
        "text-anchor": "top"
      },
      "paint": {
        "text-color": "#A7B4BE",
        "text-halo-color": "#F7FAFC",
        "text-halo-width": 1.0
      }
    }
  ]
}
